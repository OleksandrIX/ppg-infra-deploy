scope: {{ patroni_scope }}
namespace: {{ patroni_namespace }}
name: {{ inventory_hostname }}

tags:
  nofailover: false
  noloadbalance: false
  clonefrom: false

watchdog:
  mode: off

restapi:
  listen: 0.0.0.0:8008
  connect_address: {{ ansible_default_ipv4.address }}:8008
  authentication:
    username: {{ patroni_restapi_user }}
    password: {{ patroni_restapi_password }}

log:
  dir: /var/log/patroni
  mode: 0644
  level: INFO
  traceback_level: ERROR
  file_num: 10
  file_size: 100000000
  dateformat: "%Y-%m-%d %H:%M:%S"

etcd3:
  protocol: http
  hosts:
  {% for host in etcd_hosts %}
    - {{ hostvars[host]['ansible_default_ipv4']['address'] }}:2379
  {% endfor %}

postgresql:
  listen: {{ ansible_default_ipv4.address }}:5432
  connect_address: {{ ansible_default_ipv4.address }}:5432
  data_dir: {{ psql_data_dir }}
  bin_dir: {{ psql_bin_dir }}
  authentication:
    superuser:
      username: postgres
      password: {{ psql_superuser_password }}
    replication:
      username: replicator
      password: {{ psql_replication_password }}
  parameters:
    unix_socket_directories: "/var/run/postgresql/"

bootstrap:
  dcs:
    ttl: 30
    loop_wait: 10
    retry_timeout: 10
    maximum_lag_on_failover: 1048576
    postgresql:
      use_pg_rewind: true
      use_slots: true
      create_replica_methods:
{% for method in patroni_create_replica_methods %}
        - "{{ method }}"
{% endfor %}
      pgbackrest:
        command: "pgbackrest --stanza={{ pgbackrest_stanza }} --delta restore"
        keep_data: true
        no_params: true
      recovery_conf:
        restore_command: "pgbackrest --stanza={{ pgbackrest_stanza }} archive-get %f %p"
      parameters:
        archive_mode: true
        archive_timeout: "600s"
        archive_command: "pgbackrest --stanza={{ pgbackrest_stanza }} archive-push %p"
        restore_command: "pgbackrest --stanza={{ pgbackrest_stanza }} archive-get %f %p"
        shared_buffers: "2GB"
        effective_cache_size: "6GB"
        maintenance_work_mem: "1GB"
        work_mem: "16MB"
        hot_standby: true
        password_encryption: "{{ psql_password_encryption }}"
        log_connections: true
        log_destination: "stderr"
        log_directory: "/var/log/postgresql"
        log_disconnections: true
        log_duration: false
        log_min_duration_statement: "1000ms"
        log_error_verbosity: "verbose"
        log_file_mode: "0640"
        log_filename: "postgresql.log"
        log_line_prefix: "%m [pid=%p] user=%u db=%d app=%a "
        log_min_messages: "info"
        log_rotation_age: "1d"
        log_rotation_size: 0
        log_statement: "ddl"
        log_truncate_on_rotation: "off"
        logging_collector: "on"
        max_connections: 100
        max_prepared_transactions: 100
        max_replication_slots: 10
        max_wal_senders: 5
        min_wal_size: "256MB"
        max_wal_size: "1GB"
        max_slot_wal_keep_size: "10GB"
        wal_buffers: "16MB"
        wal_keep_size: "160MB"
        wal_level: "replica"
        wal_log_hints: true

      pg_hba:
{% for host in postgres_hosts %}
        - host all all {{ hostvars[host]['ansible_default_ipv4']['address'] }}/32 {{ psql_password_encryption }}
        - host replication replicator {{ hostvars[host]['ansible_default_ipv4']['address'] }}/32 {{ psql_password_encryption }}
{% endfor %}
        - local all postgres peer
        - local all all {{ psql_password_encryption }}
        - host all all 127.0.0.1/32 {{ psql_password_encryption }}
        - host all postgres 0.0.0.0/0 reject
{% for host in allow_connection_hosts %}
        - host all all {{ hostvars[host]['ansible_default_ipv4']['address'] }}/32 {{ psql_password_encryption }}
{% endfor %}

  initdb:
    - encoding: UTF8
    - data-checksums
