global
  log /dev/log local0
  log /dev/log local1 notice
  chroot /var/lib/haproxy
  stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
  stats timeout 30s
  user haproxy
  group haproxy
  daemon
  maxconn 1000

defaults
  log     global
  mode    tcp
  option  tcplog
  option  dontlognull
  timeout check   5s
  timeout connect 5s
  timeout client  10m
  timeout server  10m
  retries 3

# Stats page
listen stats
  bind *:{{ haproxy_stats_port }}
  mode http
  stats enable
  stats uri /stats
  stats refresh 5s
  stats show-legends
  stats show-node
  stats auth {{ haproxy_stats_user }}:{{ haproxy_stats_password }}

# Listen: primary
listen primary
  bind {{ haproxy_vip }}:{{ haproxy_primary_port }}
  option httpchk GET /primary
  http-check expect status 200
  default-server inter 2s fastinter 1s rise 2 fall 2 on-marked-down shutdown-sessions
{% for host in postgres_hosts %}
  server {{ host }} {{ hostvars[host]['ansible_default_ipv4']['address'] }}:{{ pgbouncer_port }} check port {{ haproxy_patroni_port }}
{% endfor %}

# Listen: replicas
listen replicas
  bind {{ haproxy_vip }}:{{ haproxy_replica_port }}
  option httpchk GET /replica
  http-check expect status 200
  balance leastconn
  default-server inter 2s fastinter 1s rise 2 fall 2 on-marked-down shutdown-sessions
{% for host in postgres_hosts %}
  server {{ host }} {{ hostvars[host]['ansible_default_ipv4']['address'] }}:{{ pgbouncer_port }} check port {{ haproxy_patroni_port }}
{% endfor %}
