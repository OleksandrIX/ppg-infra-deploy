global
  log /dev/log local0
  log /dev/log local1 notice
  chroot /var/lib/haproxy
  stats socket /run/haproxy/admin.sock mode 660 level admin expose-fd listeners
  stats timeout 30s
  user haproxy
  group haproxy
  daemon
  maxconn 1000

defaults
  log     global
  mode    tcp
  option  tcplog
  option  dontlognull
  timeout check   5s
  timeout connect 5s
  timeout client  10m
  timeout server  10m
  retries 3

# Stats page
frontend stats
  bind *:{{ haproxy_stats_port }}
  mode http
  stats enable
  stats uri /stats
  stats refresh 5s
  stats show-legends
  stats show-node
  stats auth {{ haproxy_stats_user }}:{{ haproxy_stats_password }}

# Frontend: primary
frontend primary
  bind {{ haproxy_vip }}:{{ haproxy_primary_port }}
  default_backend primary_backend

# Backend: primary
backend primary_backend
  option httpchk GET /primary
  http-check expect status 200
{% for host in postgres_hosts %}
  server {{ host }} {{ hostvars[host]['ansible_default_ipv4']['address'] }}:{{ psql_port }} check port {{ haproxy_patroni_port }} inter 2s fastinter 1s rise 2 fall 2
{% endfor %}

# Frontend: replicas
frontend replicas
  bind {{ haproxy_vip }}:{{ haproxy_replica_port }}
  default_backend replica_backend

# Backend: replicas
backend replica_backend
  option httpchk GET /replica
  http-check expect status 200
  balance leastconn
{% for host in postgres_hosts %}
  server {{ host }} {{ hostvars[host]['ansible_default_ipv4']['address'] }}:{{ psql_port }} check port {{ haproxy_patroni_port }} inter 2s fastinter 1s rise 2 fall 2
{% endfor %}
