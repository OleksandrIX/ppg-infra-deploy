#!/bin/bash
# Managed by Ansible - DO NOT EDIT THIS FILE
#
# pgBackRest backup script for POSIX repository host
# Usage: pgbackrest-backup.sh [full|diff|incr]

STANZA="{{ pgbackrest_stanza }}"
BACKUP_TYPE="${1:-full}"
LOG_FILE="/var/log/pgbackrest/backup.log"

log() {
  echo "$(date '+%Y-%m-%d %H:%M:%S') [${1}] ${2}" | tee -a "${LOG_FILE}"
}

log "INFO" "Starting pgBackRest ${BACKUP_TYPE} backup for stanza '${STANZA}'..."

pgbackrest --stanza="${STANZA}" --type="${BACKUP_TYPE}" backup
EXIT_CODE=$?

if [ "${EXIT_CODE}" -eq 0 ]; then
  log "INFO" "pgBackRest ${BACKUP_TYPE} backup completed successfully."
else
  log "ERROR" "pgBackRest ${BACKUP_TYPE} backup failed with exit code ${EXIT_CODE}."
fi

exit "${EXIT_CODE}"
