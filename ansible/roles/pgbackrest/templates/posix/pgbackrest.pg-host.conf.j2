#================================================================================
# MANAGED BY ANSIBLE - DO NOT EDIT THIS FILE
#================================================================================

#================================================================================
# GLOBAL CONFIG FOR POSIX STORAGE
#================================================================================
[global]
# --- REPO SETTINGS (POSIX) -----------------------------------------------------
repo1-type=posix
repo1-host={{ pgbackrest_repo_host }}
repo1-host-user={{ pgbackrest_user }}
repo1-path={{ pgbackrest_repo_path }}

# --- ENCRYPTION SETTINGS --------------------------------------------------------
repo1-cipher-pass={{ pgbackrest_cipher_pass }}
repo1-cipher-type=aes-256-cbc

# --- RETENTION SETTINGS --------------------------------------------------------
repo1-retention-full=3
repo1-retention-diff=1
repo1-bundle=y
repo1-block=y

# --- OTHER SETTINGS -----------------------------------------------------------
backup-standby=prefer
process-max=4
compress-type=zst
start-fast=y

# --- LOGGING SETTINGS ----------------------------------------------------------
log-level-file=detail
log-level-console=info

#================================================================================
# STANZA CONFIGURATION
#================================================================================
[{{ pgbackrest_stanza }}]
pg1-path={{ psql_data_dir }}

{% for host in postgres_hosts | reject('equalto', inventory_hostname) %}
pg{{ loop.index + 1 }}-path={{ psql_data_dir }}
pg{{ loop.index + 1 }}-host={{ hostvars[host]['ansible_default_ipv4']['address'] }}
pg{{ loop.index + 1 }}-host-user={{ pgbackrest_user }}
{% endfor %}
